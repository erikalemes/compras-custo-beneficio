# ===== Compras Custo-Beneficio — variaveis de ambiente =====
# Copie para .env e preencha apenas o que for usar.
# O modo demonstracao funciona sem NENHUMA credencial.

# Modo de operacao: demo | public | production
APP_MODE=demo

# Nome exibido na interface (troca centralizada do nome do produto)
APP_NAME=Compras Custo-Benefício

# Banco de dados (SQLite por padrao; use postgresql+psycopg://... em producao)
DATABASE_URL=sqlite:///./app.db

# CORS: origens permitidas, separadas por virgula
CORS_ORIGINS=http://localhost:3000

# Mascarar CEP nos logs (recomendado: true)
MASK_CEP_IN_LOGS=true

# ----- Fontes reais (opcionais; sem elas a fonte fica em modo simulado) -----
# Amazon Product Advertising API (PA-API 5.0)
AMAZON_PAAPI_ACCESS_KEY=
AMAZON_PAAPI_SECRET_KEY=
AMAZON_PAAPI_PARTNER_TAG=

# Mercado Livre (API publica de busca; token opcional aumenta limites)
MELI_ACCESS_TOKEN=

# ----- IA opcional (interpretacao de consulta; app funciona sem) -----
ANTHROPIC_API_KEY=

# ----- Frontend -----
NEXT_PUBLIC_API_URL=http://localhost:8000
